# ── SECURITY ─────────────────────────────────────────────────────────────
# Generate a secure secret key for production
# Use: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=django-insecure-change-this-in-production-use-a-secure-random-key

# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1


# ── DATABASE CONFIGURATION ───────────────────────────────────────────────────
# SQLite (default for development)
# No configuration needed - uses db.sqlite3

# PostgreSQL (uncomment for production)
# DB_NAME=omnexa_ai
# DB_USER=omnexa_user
# DB_PASSWORD=your_secure_password
# DB_HOST=localhost
# DB_PORT=5432


# ── EMAIL CONFIGURATION ─────────────────────────────────────────────────────
# SMTP settings for sending emails
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Default from email
DEFAULT_FROM_EMAIL=OMNEXA AI <hello@omnexa.ai>

# Admin email for notifications
ADMIN_EMAIL=admin@omnexa.ai


# ── CORS CONFIGURATION ─────────────────────────────────────────────────────
# Allowed origins for CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://omnexa.ai,https://www.omnexa.ai


# ── OPTIONAL: CELERY CONFIGURATION (for async tasks) ───────────────────────
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0


# ── OPTIONAL: OPENAI API (for smart chatbot responses) ─────────────────────
# OPENAI_API_KEY=your-openai-api-key


# ── OPTIONAL: AWS S3 (for media storage in production) ────────────────────
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=omnexa-media
# AWS_S3_REGION_NAME=us-east-1


# ── OPTIONAL: SENTRY (for error tracking in production) ───────────────────
# SENTRY_DSN=your-sentry-dsn
